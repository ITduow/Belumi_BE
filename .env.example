# =============================================================
# BELUMI BACKEND — Environment Variables Template
# =============================================================
# HƯỚNG DẪN:
#   1. Copy file này: cp .env.example .env
#   2. Điền các giá trị thật vào .env
#   3. KHÔNG BAO GIỜ commit file .env lên Git
#   4. File này (.env.example) là an toàn để commit vì không có giá trị thật
# =============================================================

# ─── DATABASE ────────────────────────────────────────────────
# Lấy từ AWS RDS → PostgreSQL Connection String
ConnectionStrings__DefaultConnection=

# ─── JWT AUTHENTICATION ──────────────────────────────────────
# Tạo random string dài tối thiểu 32 ký tự
# Ví dụ (KHÔNG dùng cái này): openssl rand -base64 32
JwtSettings__SecretKey=
JwtSettings__Issuer=Belumi_App
JwtSettings__Audience=Belumi_App_Users
JwtSettings__ExpirationInDays=7

# ─── EMAIL / SMTP ─────────────────────────────────────────────
# Gmail App Password: https://myaccount.google.com/apppasswords
# Tạo App Password mới cho Belumi, KHÔNG dùng mật khẩu Gmail thật
SMTP__Host=smtp.gmail.com
SMTP__Port=587
SMTP__User=
SMTP__Pass=
SMTP__From=
SMTP__DisplayName=Belumi App

# ─── GEMINI AI API ────────────────────────────────────────────
# Tạo API Key tại: https://aistudio.google.com/app/apikey
# MỖI DEVELOPER tạo key riêng, KHÔNG share key
Gemini__ApiKey=

# ─── FIREBASE ADMIN SDK ───────────────────────────────────────
# Lấy từ Firebase Console → Project Settings → Service Accounts
# → Generate new private key → Download JSON
# Dán TOÀN BỘ nội dung JSON vào đây (một dòng)
# HOẶC set GOOGLE_APPLICATION_CREDENTIALS=/path/to/file.json
FIREBASE_CREDENTIALS=

# ─── ASP.NET CORE ─────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Development
# Production: http://belumi-api.ap-southeast-1.elasticbeanstalk.com
# Development: http://localhost:5151
ASPNETCORE_URLS=http://localhost:5151
