.vs/
.idea/
*.user
*.DotSettings.user

# ─── .NET BUILD OUTPUTS ───────────────────────────────────────────────────────
bin/
obj/
TestResults/

# ─── ENVIRONMENT-SPECIFIC CONFIG (auto-generated by dotnet) ──────────────────
appsettings.Development.json
appsettings.Local.json

# ─── SECRETS — NEVER COMMIT ──────────────────────────────────────────────────
# Rule: nếu một thứ có thể đăng nhập / gọi API tính phí / truy cập DB => SECRET

# Environment files (DB passwords, JWT secrets, API keys, SMTP passwords)
.env
.env.*
*.env
!.env.example

# ASP.NET Core User Secrets
secrets.json
**/secrets.json

# Firebase Admin SDK service account (gives full Firebase DB/Auth access)
*firebase-adminsdk*.json
serviceAccountKey.json
firebase-service-account*.json

# Android signing (nếu BE có liên quan đến build Android)
*.jks
*.keystore
key.properties

# Apple certificates
*.p12
*.mobileprovision

# Cloud provider credentials
.aws/
gcp-credentials.json
azure-credentials.json

# SSH keys
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# SSL/TLS certificates with private keys
*.pfx
*.key

# ─── LOGS & TEMP ─────────────────────────────────────────────────────────────
*.log
*.tmp
